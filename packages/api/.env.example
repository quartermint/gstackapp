# Mission Control API -- Environment Variables
#
# Copy to .env and fill in values:
#   cp .env.example .env

# Server
PORT=3000
HOST=0.0.0.0

# AI Enrichment (optional -- captures still work without AI)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model for AI categorization (default: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# Config file path (optional -- defaults to ./mc.config.json)
# MC_CONFIG_PATH=/path/to/mc.config.json
