# Mission Control Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env files with real secrets

# ============================================
# Node Environment
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================
# Convex Database
# ============================================
# Get these from your Convex dashboard: https://dashboard.convex.dev
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ============================================
# Authentication
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ============================================
# Claude CLI Integration
# ============================================
# Maximum tokens for Claude responses
CLAUDE_MAX_TOKENS=4096
# Request timeout in milliseconds
CLAUDE_TIMEOUT=60000

# ============================================
# Worker Configuration (Cloudflare)
# ============================================
# Tailscale IP of the hub
HUB_URL=

# ============================================
# Compute Node Configuration
# ============================================
# Node hostname for identification
HOSTNAME=

# Sandbox settings
SANDBOX_ENABLED=true
SANDBOX_WORKDIR=/tmp/sandbox

# ============================================
# Development Only
# ============================================
# Enable debug logging
DEBUG=false

# Skip SSL verification (never in production)
# NODE_TLS_REJECT_UNAUTHORIZED=0
